# Copy to .env and fill in. .env is gitignored and chmod 600 by bootstrap.

# Required. Your Anthropic API key. Never committed, never logged (redacted everywhere).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional. Default model for opencode + warmup.
#FABLE_MODEL=claude-sonnet-4-5

# Optional. Local audit proxy port (opencode -> proxy -> api.anthropic.com).
#FABLE_PROXY_PORT=8377

# Optional. Audit log directory (default ~/.fable/audit, mode 0700).
#FABLE_AUDIT_DIR=

# Optional. Days to retain audit logs (default 365).
#FABLE_AUDIT_RETENTION_DAYS=365

# Optional. 1 = fail-closed: proxy refuses to forward if audit log is unwritable.
#FABLE_AUDIT_STRICT=0

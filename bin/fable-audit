#!/usr/bin/env python3
"""fable-audit: tail / verify / export / rotate / tokens for the Fable audit log.

Usage:
  fable-audit tail [-n N]        show the last N events (default 20)
  fable-audit verify             recompute the SHA-256 hash chain; exit 1 on tamper
  fable-audit export [--out F]   dump all events (chronological) as JSONL
  fable-audit rotate             gzip old daily logs, enforce retention
  fable-audit tokens [--date D]  aggregate token usage and cost (compare with Anthropic console)
  fable-audit errors [--quiet]   list API error responses (4xx/5xx) with bodies; exit 1 if any
"""
import argparse
import gzip
import hashlib
import json
import os
import sys
from collections import defaultdict
from pathlib import Path

AUDIT_DIR = Path(os.environ.get("FABLE_AUDIT_DIR", str(Path.home() / ".fable" / "audit")))
GENESIS = "0" * 64


def iter_events():
    files = sorted(AUDIT_DIR.glob("audit-*.jsonl.gz")) + sorted(AUDIT_DIR.glob("audit-*.jsonl"))
    files.sort(key=lambda p: p.name[6:16])
    for path in files:
        opener = gzip.open if path.suffix == ".gz" else open
        with opener(path, "rt", encoding="utf-8") as f:
            for lineno, line in enumerate(f, 1):
                line = line.strip()
                if not line:
                    continue
                try:
                    yield path, lineno, json.loads(line)
                except json.JSONDecodeError:
                    yield path, lineno, None


def cmd_tail(args):
    events = [e for _, _, e in iter_events() if e]
    for e in events[-args.n:]:
        usage = e.get("usage") or {}
        extra = ""
        if e["event_type"] in ("api_request", "api_response"):
            http = e.get("http", {})
            extra = f" {http.get('method', '')} {http.get('path', '')} {http.get('status', '')}"
            if usage:
                extra += f" in={usage.get('input_tokens')} out={usage.get('output_tokens')}"
        elif e["event_type"] in ("tool_call", "tool_result"):
            extra = f" {e.get('tool', {}).get('name') or e.get('tool', {}).get('tool_use_id', '')}"
        print(f"{e['timestamp']}  {e['event_type']:<14}{extra}")


def cmd_verify(_args):
    prev = GENESIS
    count = 0
    for path, lineno, e in iter_events():
        if e is None:
            print(f"TAMPER: unparseable line {path}:{lineno}", file=sys.stderr)
            sys.exit(1)
        claimed = e.pop("hash", None)
        if e.get("prev_hash") != prev:
            print(f"TAMPER: chain break at {path}:{lineno} "
                  f"(expected prev_hash {prev[:12]}…, got {str(e.get('prev_hash'))[:12]}…)", file=sys.stderr)
            sys.exit(1)
        payload = json.dumps(e, sort_keys=True, ensure_ascii=False)
        computed = hashlib.sha256((prev + payload).encode()).hexdigest()
        if computed != claimed:
            print(f"TAMPER: hash mismatch at {path}:{lineno}", file=sys.stderr)
            sys.exit(1)
        prev = computed
        count += 1
    print(f"OK: {count} events verified, chain intact")


def cmd_export(args):
    out = open(args.out, "w", encoding="utf-8") if args.out else sys.stdout
    for _, _, e in iter_events():
        if e:
            out.write(json.dumps(e, sort_keys=True, ensure_ascii=False) + "\n")
    if args.out:
        out.close()
        print(f"exported to {args.out}", file=sys.stderr)


def cmd_errors(args):
    """Surface API error responses captured by the proxy (the full bodies the
    TUI truncates). Exit 1 if any errors found — usable as a CI/smoke gate."""
    found = 0
    for _, _, e in iter_events():
        if not e or e.get("event_type") != "api_response":
            continue
        status = (e.get("http") or {}).get("status")
        body = e.get("response")
        body_str = body if isinstance(body, str) else json.dumps(body or "")
        is_error = (isinstance(status, int) and status >= 400) or '"type":"error"' in body_str.replace(" ", "")
        if not is_error:
            continue
        found += 1
        if not args.quiet:
            print(f"--- {e['timestamp']}  model={e.get('model', '?')}  status={status}")
            try:
                parsed = json.loads(body_str) if isinstance(body_str, str) else body_str
                err = parsed.get("error", {}) if isinstance(parsed, dict) else {}
                print(f"    {err.get('type', '?')}: {err.get('message', body_str[:200])}")
            except (json.JSONDecodeError, AttributeError):
                print(f"    {body_str[:200]}")
    if not args.quiet:
        print(f"\n{found} API error(s) found" if found else "no API errors found")
    sys.exit(1 if found else 0)


def cmd_rotate(_args):
    sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "proxy"))
    from audit_proxy import AuditLog  # noqa: PLC0415
    AuditLog(AUDIT_DIR).rotate()
    print("rotation complete")


# Pricing per 1M tokens (USD) — update when Anthropic changes pricing
PRICING = {
    # model-prefix: (input, output, cache_read, cache_write)
    "claude-sonnet-4-5":    (10.00, 50.00, 1.00, 12.50),
    "claude-sonnet-4-5":  (3.00,  15.00, 0.30, 3.75),
    "claude-sonnet-4-6":  (3.00,  15.00, 0.30, 3.75),
    "claude-sonnet-4-20250514":  (3.00,  15.00, 0.30, 3.75),
    "claude-sonnet-4-5-20250929": (3.00,  15.00, 0.30, 3.75),
    "claude-opus-4":     (15.00, 75.00, 1.50, 18.75),
    "claude-opus-4-20250514":  (15.00, 75.00, 1.50, 18.75),
    "claude-haiku-3-5":  (0.80,  4.00,  0.08, 1.00),
    "claude-haiku-4-5":  (0.80,  4.00,  0.08, 1.00),
    "claude-haiku-4-5-20250929": (0.80,  4.00,  0.08, 1.00),
}


def _lookup_pricing(model_str):
    if not model_str:
        return None
    m = model_str.lower().replace("anthropic/", "")
    for prefix, pricing in PRICING.items():
        if m.startswith(prefix) or prefix.startswith(m):
            return pricing
    return None


def cmd_tokens(args):
    date_filter = args.date  # e.g. "2026-06-12" or None for all
    by_model = defaultdict(lambda: {
        "requests": 0,
        "input_tokens": 0,
        "output_tokens": 0,
        "cache_read_input_tokens": 0,
        "cache_creation_input_tokens": 0,
    })
    events_with_usage = 0
    events_without_usage = 0

    for _, _, e in iter_events():
        if e is None or e.get("event_type") != "api_response":
            continue
        http = e.get("http", {})
        if http.get("status") != 200:
            continue
        if date_filter:
            ts = e.get("timestamp", "")
            if not ts.startswith(date_filter):
                continue

        usage = e.get("usage")
        model = e.get("model") or "unknown"
        if not usage or not isinstance(usage, dict):
            events_without_usage += 1
            continue

        events_with_usage += 1
        row = by_model[model]
        row["requests"] += 1
        row["input_tokens"] += usage.get("input_tokens", 0)
        row["output_tokens"] += usage.get("output_tokens", 0)
        row["cache_read_input_tokens"] += usage.get("cache_read_input_tokens", 0)
        row["cache_creation_input_tokens"] += usage.get("cache_creation_input_tokens", 0)

    if not by_model:
        print("no usage data found" + (f" for {date_filter}" if date_filter else ""))
        return

    hdr = (f"{'model':<36} {'reqs':>5} {'input':>10} {'output':>10} "
           f"{'cache_read':>12} {'cache_write':>12} {'TOTAL':>12} {'est_cost':>10}")
    print(hdr)
    print("-" * len(hdr))

    grand = {"requests": 0, "input_tokens": 0, "output_tokens": 0,
             "cache_read_input_tokens": 0, "cache_creation_input_tokens": 0, "cost": 0.0}

    for model, row in sorted(by_model.items()):
        pricing = _lookup_pricing(model)
        if pricing:
            inp_p, out_p, cr_p, cw_p = pricing
            cost = (row["input_tokens"] * inp_p
                    + row["output_tokens"] * out_p
                    + row["cache_read_input_tokens"] * cr_p
                    + row["cache_creation_input_tokens"] * cw_p) / 1_000_000
        else:
            cost = 0.0
        total = (row["input_tokens"] + row["output_tokens"]
                 + row["cache_read_input_tokens"] + row["cache_creation_input_tokens"])
        cost_str = f"${cost:.4f}" if pricing else "n/a"
        print(f"{model:<36} {row['requests']:>5} {row['input_tokens']:>10,} {row['output_tokens']:>10,} "
              f"{row['cache_read_input_tokens']:>12,} {row['cache_creation_input_tokens']:>12,} "
              f"{total:>12,} {cost_str:>10}")
        grand["requests"] += row["requests"]
        grand["input_tokens"] += row["input_tokens"]
        grand["output_tokens"] += row["output_tokens"]
        grand["cache_read_input_tokens"] += row["cache_read_input_tokens"]
        grand["cache_creation_input_tokens"] += row["cache_creation_input_tokens"]
        grand["cost"] += cost

    grand_total = (grand["input_tokens"] + grand["output_tokens"]
                   + grand["cache_read_input_tokens"] + grand["cache_creation_input_tokens"])
    print("-" * len(hdr))
    print(f"{'TOTAL':<36} {grand['requests']:>5} {grand['input_tokens']:>10,} {grand['output_tokens']:>10,} "
          f"{grand['cache_read_input_tokens']:>12,} {grand['cache_creation_input_tokens']:>12,} "
          f"{grand_total:>12,} ${grand['cost']:>9.4f}")

    print(f"\n{events_with_usage} responses with usage, {events_without_usage} without")
    print(f"\nReconciliation: TOTAL column should match Anthropic console token count.")
    print(f"  Proxy total: {grand_total:,} tokens")
    if events_without_usage:
        print("  (some responses missing usage — re-run after new sessions with updated proxy)")


def main():
    parser = argparse.ArgumentParser(prog="fable-audit", description=__doc__,
                                     formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = parser.add_subparsers(dest="cmd", required=True)
    p_tail = sub.add_parser("tail")
    p_tail.add_argument("-n", type=int, default=20)
    sub.add_parser("verify")
    p_exp = sub.add_parser("export")
    p_exp.add_argument("--out")
    sub.add_parser("rotate")
    p_tok = sub.add_parser("tokens")
    p_tok.add_argument("--date", help="filter to a specific date (YYYY-MM-DD)")
    p_err = sub.add_parser("errors")
    p_err.add_argument("--quiet", action="store_true", help="no output, exit code only")
    args = parser.parse_args()
    {"tail": cmd_tail, "verify": cmd_verify, "export": cmd_export,
     "rotate": cmd_rotate, "tokens": cmd_tokens, "errors": cmd_errors}[args.cmd](args)


if __name__ == "__main__":
    main()

# SMTP credentials for send-email skill
# Copy to ~/.fable/smtp.env and chmod 600 it.
# Gmail: use an App Password (myaccount.google.com/apppasswords), not your real password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
# Optional; defaults to SMTP_USER
SMTP_FROM=you@gmail.com

#!/data/data/com.termux/files/usr/bin/bash
# skill — manage pocket-agent skills
# Usage: skill list | skill info <name> | skill install <name> [--registry <git-url-or-path>] | skill run <name> [args...]
set -euo pipefail
SKILLS_DIR="${FABLE_SKILLS:-$HOME/.fable/skills}"
REGISTRY="${FABLE_REGISTRY:-https://github.com/salus-ryan/opencodeprojects.git}"
REG_CACHE="$HOME/.fable/.registry-cache"
RUN_LOG="$HOME/.fable/skill-runs.jsonl"

yamlval() { grep "^$2:" "$1" | head -1 | cut -d: -f2- | sed 's/^ *//;s/ *$//'; }

# extract an indented block under a top-level key (e.g. budget:, audit:)
yamlblock() { awk -v key="$2:" '$0==key{f=1;next} f&&/^[^ ]/{f=0} f' "$1"; }

case "${1:-list}" in
  list)
    printf "%-22s %-10s %s\n" "NAME" "VERSION" "DESCRIPTION"
    for m in "$SKILLS_DIR"/*/skill.yaml; do
      [ -f "$m" ] || continue
      printf "%-22s %-10s %s\n" "$(yamlval "$m" name)" "$(yamlval "$m" version)" "$(yamlval "$m" description)"
    done
    ;;
  info)
    name="${2:?usage: skill info <name>}"
    m="$SKILLS_DIR/$name/skill.yaml"
    [ -f "$m" ] || { echo "no such skill: $name"; exit 1; }
    cat "$m"
    ;;
  install)
    name="${2:?usage: skill install <name>}"
    [ "${3:-}" = "--registry" ] && REGISTRY="$4"
    if [ -d "$REGISTRY" ]; then
      src="$REGISTRY/skills/$name"
    else
      if [ -d "$REG_CACHE/.git" ]; then
        git -C "$REG_CACHE" pull --quiet 2>/dev/null || true
      else
        git clone --quiet --depth 1 "$REGISTRY" "$REG_CACHE"
      fi
      src="$REG_CACHE/skills/$name"
    fi
    [ -d "$src" ] || { echo "skill '$name' not found in registry"; exit 1; }
    m="$src/skill.yaml"
    [ -f "$m" ] || { echo "skill '$name' has no manifest; refusing to install"; exit 1; }
    echo "Installing: $(yamlval "$m" name) v$(yamlval "$m" version)"
    echo "  $(yamlval "$m" description)"
    echo "  permissions: $(yamlval "$m" permissions)"
    echo "  requirements: $(yamlval "$m" requirements)"
    # requirement check: bins
    reqs=$(yamlval "$m" requirements)
    bins=$(echo "$reqs" | grep -o 'bins: \[[^]]*\]' | sed 's/bins: \[//;s/\]//;s/,/ /g' || true)
    missing=""
    for b in $bins; do command -v "$b" >/dev/null || missing="$missing $b"; done
    [ -n "$missing" ] && { echo "  MISSING bins:$missing — install them first"; exit 1; }
    mkdir -p "$SKILLS_DIR/$name"
    cp "$src"/* "$SKILLS_DIR/$name/"
    chmod +x "$SKILLS_DIR/$name/$(yamlval "$m" entrypoint)" 2>/dev/null || true
    echo "  installed -> $SKILLS_DIR/$name/"
    ;;
  run)
    name="${2:?usage: skill run <name> [args...]}"; shift 2
    dir="$SKILLS_DIR/$name"; m="$dir/skill.yaml"
    [ -f "$m" ] || { echo "no such skill: $name"; exit 1; }
    entry="$(yamlval "$m" entrypoint)"
    [ -x "$dir/$entry" ] || { echo "entrypoint not executable: $dir/$entry"; exit 1; }
    # 1. requirements: bins must exist
    reqs=$(yamlval "$m" requirements)
    bins=$(echo "$reqs" | grep -o 'bins: \[[^]]*\]' | sed 's/bins: \[//;s/\]//;s/,/ /g' || true)
    missing=""
    for b in $bins; do command -v "$b" >/dev/null || missing="$missing $b"; done
    [ -n "$missing" ] && { echo "[governor] MISSING bins:$missing"; exit 1; }
    # 2. budget block: lines like "key: value  # ENV_NAME" -> export ENV_NAME=value
    while IFS= read -r line; do
      env=$(echo "$line" | grep -o '#[[:space:]]*[A-Z][A-Z0-9_]*' | sed 's/#[[:space:]]*//' | head -1 || true)
      val=$(echo "$line" | sed 's/#.*//' | cut -d: -f2- | sed 's/^ *//;s/ *$//')
      if [ -n "$env" ] && [ -n "$val" ]; then
        export "$env"="$val"
        echo "[governor] $env=$val" >&2
      fi
    done < <(yamlblock "$m" budget | grep ':' || true)
    # 3a. biometric gate (require_biometric_for) — termux-fingerprint or passphrase via bio-gate
    bios=$(yamlblock "$m" audit | awk '/require_biometric_for:/{f=1;next} f&&/^[ ]*-/{print $2} f&&!/^[ ]*-/{f=0}' || true)
    if [ -n "$bios" ]; then
      gate="$SKILLS_DIR/bio-gate/bio-gate.sh"
      [ -x "$gate" ] || { echo "[governor] '$name' requires biometric gate but bio-gate skill not installed"; exit 1; }
      "$gate" "skill '$name':$(echo $bios | tr '\n' ' ')" || { echo "[governor] biometric denied"; exit 1; }
    fi
    # 3b. confirmation gate
    confirms=$(yamlblock "$m" audit | awk '/require_human_confirmation_for:/{f=1;next} f&&/^[ ]*-/{print $2} f&&!/^[ ]*-/{f=0}' || true)
    if [ -n "$confirms" ]; then
      echo "[governor] '$name' requires confirmation for:$(echo $confirms | tr '\n' ' ')" >&2
      printf "[governor] proceed? [y/N] " >&2; read -r ans
      [ "$ans" = "y" ] || { echo "[governor] denied"; exit 1; }
    fi
    # 4. audited execution (bound to BBID session identity when available)
    bbid=""
    [ -x "$SKILLS_DIR/bbid/bbid.py" ] && bbid=$(python3 "$SKILLS_DIR/bbid/bbid.py" --quiet 2>/dev/null || true)
    start=$(date +%s); ts=$(date -u +%Y-%m-%dT%H:%M:%SZ); rc=0
    "$dir/$entry" "$@" || rc=$?
    dur=$(( $(date +%s) - start ))
    printf '{"ts":"%s","skill":"%s","version":"%s","args":%s,"exit":%d,"duration_s":%d,"bbid":"%s"}\n' \
      "$ts" "$name" "$(yamlval "$m" version)" \
      "$(printf '%s' "$*" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')" \
      "$rc" "$dur" "$bbid" >> "$RUN_LOG"
    exit $rc
    ;;
  *)
    echo "usage: skill list | skill info <name> | skill install <name> [--registry <url-or-path>] | skill run <name> [args...]"; exit 2 ;;
esac
